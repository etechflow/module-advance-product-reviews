<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="ETechFlow_AdvancedProductReviews" setup_version="1.0.0">
        <sequence>
            <module name="Magento_Review"/>
            <module name="Magento_Catalog"/>
            <module name="Magento_Customer"/>
            <module name="Magento_Sales"/>
            <module name="Magento_SalesRule"/>
            <module name="Magento_Store"/>
            <module name="Magento_Ui"/>
            <!-- Soft ordering only: when a Hyvä store has Hyva_Theme installed,
                 load this module after it so the bundled Hyvä reviews template
                 wins. Safely ignored on stores without Hyvä. -->
            <module name="Hyva_Theme"/>
        </sequence>
    </module>
</config>
