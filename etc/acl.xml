<?xml version="1.0"?>
<!--
/**
 * ETechFlow_AdvancedProductReviews — ACL resources
 *
 * @author ETechFlow <etechflow0@gmail.com>
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Reports::report">
                    <resource id="ETechFlow_AdvancedProductReviews::analytics"
                              title="Reviews Analytics Dashboard" sortOrder="90"/>
                </resource>
                <resource id="Magento_Backend::content">
                    <resource id="ETechFlow_AdvancedProductReviews::reviews"
                              title="Advanced Product Reviews" sortOrder="100">
                        <resource id="ETechFlow_AdvancedProductReviews::comments"
                                  title="Review Comments" sortOrder="10"/>
                        <resource id="ETechFlow_AdvancedProductReviews::questions"
                                  title="Product Questions (Q&amp;A)" sortOrder="20"/>
                        <resource id="ETechFlow_AdvancedProductReviews::answers"
                                  title="Product Answers" sortOrder="30"/>
                        <resource id="ETechFlow_AdvancedProductReviews::reminders"
                                  title="Review Reminders" sortOrder="40"/>
                    </resource>
                </resource>
                <resource id="Magento_Config::config">
                    <resource id="ETechFlow_AdvancedProductReviews::config"
                              title="Advanced Product Reviews Configuration" sortOrder="100"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
