<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="etechflow_reviews_send_reminders"
             instance="ETechFlow\AdvancedProductReviews\Cron\SendReminders"
             method="execute">
            <schedule>0 * * * *</schedule>
        </job>
    </group>
</config>
