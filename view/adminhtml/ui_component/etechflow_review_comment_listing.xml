<?xml version="1.0"?>
<!--
/**
 * ETechFlow_AdvancedProductReviews — review comments grid
 *
 * @author ETechFlow <etechflow0@gmail.com>
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_review_comment_listing.etechflow_review_comment_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>etechflow_review_comment_columns</spinner>
        <deps>
            <dep>etechflow_review_comment_listing.etechflow_review_comment_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="etechflow_review_comment_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>ETechFlow_AdvancedProductReviews::comments</aclResource>
        <dataProvider name="etechflow_review_comment_listing_data_source"
                      class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
            <settings>
                <requestFieldName>comment_id</requestFieldName>
                <primaryFieldName>comment_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="approve">
                <settings>
                    <confirm>
                        <message translate="true">Approve selected comments?</message>
                        <title translate="true">Approve Comments</title>
                    </confirm>
                    <url path="etechflow_reviews/comment/massApprove"/>
                    <type>approve</type>
                    <label translate="true">Approve</label>
                </settings>
            </action>
            <action name="reject">
                <settings>
                    <confirm>
                        <message translate="true">Reject selected comments?</message>
                        <title translate="true">Reject Comments</title>
                    </confirm>
                    <url path="etechflow_reviews/comment/massReject"/>
                    <type>reject</type>
                    <label translate="true">Reject</label>
                </settings>
            </action>
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Delete selected comments? This cannot be undone.</message>
                        <title translate="true">Delete Comments</title>
                    </confirm>
                    <url path="etechflow_reviews/comment/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="etechflow_review_comment_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>comment_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="comment_id">
            <settings>
                <filter>textRange</filter>
                <sorting>desc</sorting>
                <label translate="true">ID</label>
            </settings>
        </column>
        <column name="review_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Review ID</label>
            </settings>
        </column>
        <column name="review_title">
            <settings>
                <filter>text</filter>
                <label translate="true">Review</label>
            </settings>
        </column>
        <column name="author_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Author</label>
            </settings>
        </column>
        <column name="comment">
            <settings>
                <filter>text</filter>
                <label translate="true">Comment</label>
            </settings>
        </column>
        <column name="is_admin_reply" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <dataType>select</dataType>
                <filter>select</filter>
                <label translate="true">Store Reply</label>
            </settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="ETechFlow\AdvancedProductReviews\Model\Source\Status"/>
                <dataType>select</dataType>
                <filter>select</filter>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>
    </columns>
</listing>
