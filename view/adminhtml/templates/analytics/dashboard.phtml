    <div class="etf-chart-wrap">
        <canvas id="<?= $escaper->escapeHtmlAttr($chartId) ?>"></canvas>
    </div>
</section>
<script>
(function () {
    'use strict';
    var canvas = document.getElementById('<?= $escaper->escapeJs($chartId) ?>');
    if (!canvas || !canvas.getContext) return;

    var trend  = <?= $block->getTrendJson() ?>;
    var labels = trend.map(function(d){ return d.label; });
    var counts = trend.map(function(d){ return +d.count; });
    var maxVal = Math.max.apply(null, counts.concat([1]));

    function draw() {
        var wrap = canvas.parentElement;
        var W = wrap.offsetWidth  || 600;
        var H = wrap.offsetHeight || 220;
        canvas.width  = W;
        canvas.height = H;
        canvas.style.width  = W + 'px';
        canvas.style.height = H + 'px';

        var ctx = canvas.getContext('2d');
        var padL = 44, padR = 20, padT = 16, padB = 38;
        var plotW = W - padL - padR;
        var plotH = H - padT - padB;
        var n = labels.length;
        if (n < 1) return;

        ctx.clearRect(0, 0, W, H);

        /* Grid + Y labels */
        var gridLines = 4;
        for (var g = 0; g <= gridLines; g++) {
            var gy = padT + plotH - (g / gridLines) * plotH;
            ctx.beginPath();
            ctx.strokeStyle = '#e8e8e8'; ctx.lineWidth = 1;
            ctx.moveTo(padL, gy); ctx.lineTo(padL + plotW, gy); ctx.stroke();
            ctx.fillStyle = '#999';
            ctx.font = '11px -apple-system,sans-serif';
            ctx.textAlign = 'right';
            ctx.fillText(Math.round((g / gridLines) * maxVal), padL - 6, gy + 4);
        }

        if (n < 2) return;

        var pts = counts.map(function(v, i) {
            return {
                x: padL + (i / (n - 1)) * plotW,
                y: padT + plotH - (v / maxVal) * plotH
            };
        });

        /* X labels — up to 8 */
        ctx.fillStyle = '#888'; ctx.font = '11px -apple-system,sans-serif'; ctx.textAlign = 'center';
        var step = Math.max(1, Math.ceil(n / 8));
        for (var i = 0; i < n; i += step) {
            ctx.fillText(labels[i], pts[i].x, H - padB + 16);
        }

        /* Gradient fill */
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        for (var j = 1; j < pts.length; j++) ctx.lineTo(pts[j].x, pts[j].y);
        ctx.lineTo(pts[pts.length - 1].x, padT + plotH);
        ctx.lineTo(pts[0].x, padT + plotH);
        ctx.closePath();
        var grad = ctx.createLinearGradient(0, padT, 0, padT + plotH);
        grad.addColorStop(0, 'rgba(26,115,232,.15)');
        grad.addColorStop(1, 'rgba(26,115,232,.01)');
        ctx.fillStyle = grad; ctx.fill();

        /* Line */
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        for (var k = 1; k < pts.length; k++) ctx.lineTo(pts[k].x, pts[k].y);
        ctx.strokeStyle = '#1a73e8'; ctx.lineWidth = 2.5;
        ctx.lineJoin = 'round'; ctx.stroke();

        /* Dots */
        for (var p = 0; p < pts.length; p++) {
            ctx.beginPath();
            ctx.arc(pts[p].x, pts[p].y, 3.5, 0, Math.PI * 2);
            ctx.fillStyle = '#1a73e8'; ctx.fill();
            ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.stroke();
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', draw);
    } else {
        requestAnimationFrame(draw);
    }
    window.addEventListener('resize', function(){ requestAnimationFrame(draw); });
}());
</script>
