<?xml version="1.0"?>
<!--
/**
 * ETechFlow_AdvancedProductReviews — storefront product page wiring
 *
 * @author ETechFlow <etechflow0@gmail.com>
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="ETechFlow_AdvancedProductReviews::css/reviews.css"/>
    </head>
    <body>
        <!-- Override the core review form to control field order and inline the
             extra fields (pros/cons, recommend, photo/video). The ViewModel is
             passed in so the template can read config flags. -->
        <referenceBlock name="product.review.form"
                        template="ETechFlow_AdvancedProductReviews::review/form.phtml">
            <arguments>
                <argument name="etf_view_model" xsi:type="object">
                    ETechFlow\AdvancedProductReviews\ViewModel\ReviewData
                </argument>
            </arguments>
        </referenceBlock>

        <!-- Hyvä (Tailwind + Alpine) reviews UI, driven by this module's GraphQL
             API. The block self-detects the active theme and renders ONLY under
             a Hyvä theme, so on Luma/standard themes it outputs nothing and the
             standard review UI above is used instead. -->
        <referenceContainer name="product.info.details">
            <block class="ETechFlow\AdvancedProductReviews\Block\Hyva\ProductReviews"
                   name="etf.hyva.product.reviews"
                   template="ETechFlow_AdvancedProductReviews::hyva/review/reviews.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
